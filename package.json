{
  "name": "opti-shot",
  "version": "0.2.8",
  "private": true,
  "description": "Photo duplicate detection and management desktop app",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pretest": "npx node-gyp rebuild --directory=node_modules/better-sqlite3 --silent 2>/dev/null",
    "test": "vitest run",
    "predev": "electron-rebuild --quiet",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "tsc --noEmit",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:win": "electron-vite build && electron-builder --win",
    "build:linux": "electron-vite build && electron-builder --linux",
    "postinstall": "electron-rebuild"
  },
  "keywords": [
    "photo",
    "duplicate",
    "desktop",
    "electron"
  ],
  "author": {
    "name": "shockz",
    "email": "shockz@users.noreply.github.com"
  },
  "license": "MIT",
  "build": {
    "appId": "com.optishot.app",
    "productName": "OptiShot",
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": ["nsis", "portable"]
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Utility"
    },
    "files": [
      "out/",
      "build/"
    ],
    "publish": {
      "provider": "github",
      "owner": "shockzinfinity",
      "repo": "opti-shot"
    }
  },
  "packageManager": "bun@1.3.12",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.4",
    "drizzle-kit": "^0.31.10",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.2",
    "electron-updater": "^6.8.3",
    "exifr": "^7.1.3",
    "heic-convert": "^2.1.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1",
    "react-window": "^1.8.11",
    "sharp": "^0.34.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  }
}
